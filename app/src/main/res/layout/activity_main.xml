<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Layer 0: Camera preview (Stage 2) -->
    <androidx.camera.view.PreviewView
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Layer 1: AR reticle overlay (Stage 2) -->
    <com.dwm3000.tracker.ui.ArOverlayView
        android:id="@+id/arOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Layer 2: Top HUD — status + telemetry (semi-transparent) -->
    <LinearLayout
        android:id="@+id/hudTop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#88000000"
        android:padding="12dp"
        android:layout_gravity="top">

        <!-- Status bar -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Idle"
            android:textColor="#88AAAA"
            android:textSize="13sp" />

        <!-- Telemetry row -->
        <LinearLayout
            android:id="@+id/llTelemetry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:visibility="gone">

            <!-- Distance -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DIST"
                    android:textColor="#557777"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--.- m"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Azimuth -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AZ"
                    android:textColor="#557777"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvAzimuth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--.-°"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Elevation -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EL"
                    android:textColor="#557777"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvElevation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--.-°"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Layer 3: Bottom controls -->
    <LinearLayout
        android:id="@+id/hudBottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:padding="12dp">

        <!-- Mini radar (small, bottom-right corner) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <com.dwm3000.tracker.ui.RadarView
                android:id="@+id/radarView"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_gravity="end"
                android:alpha="0.85" />
        </FrameLayout>

        <!-- Role buttons -->
        <LinearLayout
            android:id="@+id/llButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnController"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Controller"
                android:textAllCaps="false"
                app:backgroundTint="#CC1A3A3A"
                android:textColor="#00FF88" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnControlee"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Controlee"
                android:textAllCaps="false"
                app:backgroundTint="#CC1A3A3A"
                android:textColor="#00FF88" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStop"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="8dp"
            android:text="Stop"
            android:textAllCaps="false"
            android:visibility="gone"
            app:backgroundTint="#CC3A1A1A"
            android:textColor="#FF4444" />
    </LinearLayout>

</FrameLayout>
